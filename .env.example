# 体育博彩数据源 BFF — 环境变量样板（**仅用于本地开发**）
#
# 真实凭证在 Railway 服务环境变量中维护，禁止填入此文件。
# 复制为 .env.local 用于本地 docker-compose；.env.local 已在 .gitignore。

# ── 部署模式 ────────────────────────────────────────────────
# live   = 连真实 FeedConstruct RMQ + WebAPI（需要 FC_* 全量配置）
# replay = 重放 raw/json 样本（不连外部，便于本地与 PoC）
FEED_MODE=replay

# ── Postgres ─────────────────────────────────────────────────
# Railway: 由 Postgres 插件注入；本地由 docker-compose 提供
DATABASE_URL=postgres://bff:bff@postgres:5432/bff?sslmode=disable

# ── 内部 RabbitMQ（用于 BFF 内部 fanout / replay；非 FeedConstruct） ─
# Railway: 由 RabbitMQ 插件注入；本地由 docker-compose 提供
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── BFF HTTP / WS ───────────────────────────────────────────
PORT=8080
WS_ALLOWED_ORIGINS=http://localhost:3000

# ── FeedConstruct WebAPI（FEED_MODE=live 必填） ─────────────
FC_API_BASE=
FC_API_USER=
FC_API_PASS=

# ── FeedConstruct RMQ（FEED_MODE=live 必填） ────────────────
FC_RMQ_HOST=
FC_RMQ_USER=
FC_RMQ_PASS=
FC_RMQ_TLS=true
FC_PARTNER_ID=

# ── 行为开关 ────────────────────────────────────────────────
RECOVERY_INITIAL=true
LOG_LEVEL=info

# ── 前端 ────────────────────────────────────────────────────
NEXT_PUBLIC_BFF_HTTP=http://localhost:8080
NEXT_PUBLIC_BFF_WS=ws://localhost:8080/ws
